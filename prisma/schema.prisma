// ── RFID / BLE Asset Tracking ──────────────────────────────────────────────

enum RFIDTagStatus {
  ACTIVE
  INACTIVE
  LOW_BATTERY
  MISSING
  UNASSIGNED
}

model FloorPlan {
  id             String      @id @default(cuid())
  name           String
  building       String?
  floorNumber    Int?
  imageUrl       String
  imageWidth     Int         @default(1000)
  imageHeight    Int         @default(700)
  organizationId String?
  createdAt      DateTime    @default(now())
  zones          RFIDZone[]
}

model RFIDZone {
  id             String      @id @default(cuid())
  name           String
  description    String?
  apMacAddress   String?
  apIpAddress    String?
  apSerialNumber String?
  floorNumber    String?
  roomNumber     String?
  building       String?
  isRestricted   Boolean     @default(false)
  isExitZone     Boolean     @default(false) // Zone at building exits/entrances — triggers exit alerts
  floorPlanId    String?
  floorPlan      FloorPlan?  @relation(fields: [floorPlanId], references: [id])
  mapX           Float?
  mapY           Float?
  mapWidth       Float?
  mapHeight      Float?
  organizationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tags           RFIDTag[]   @relation("CurrentZone")
  roomTags       RFIDTag[]   @relation("RoomTagZone")
  scans          RFIDScan[]
}

model RFIDTag {
  id             String        @id @default(cuid())
  tagId          String        @unique
  tagType        String        @default("BLE")
  assetId        String?       @unique
  asset          Asset?        @relation(fields: [assetId], references: [id])
  status         RFIDTagStatus @default(UNASSIGNED)
  batteryLevel   Int?
  lastRssi       Int?
  lastSeenAt     DateTime?
  lastZoneId     String?
  lastZone       RFIDZone?     @relation("CurrentZone", fields: [lastZoneId], references: [id])
  manufacturer   String?
  model          String?
  notes          String?
  organizationId String?
  // Room tag support: when isRoomTag=true, this tag represents a physical room/location
  isRoomTag      Boolean       @default(false)
  roomZoneId     String?       // Links to RFIDZone that defines the room's floor/room number
  roomZone       RFIDZone?     @relation("RoomTagZone", fields: [roomZoneId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  scans          RFIDScan[]
  alerts         RFIDAlert[]
}

model RFIDScan {
  id         String    @id @default(cuid())
  tagId      String
  tag        RFIDTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  zoneId     String?
  zone       RFIDZone? @relation(fields: [zoneId], references: [id])
  apMac      String?
  rssi       Int?
  batteryRaw Int?
  rawPayload String?
  rawData    Json?
  createdAt  DateTime  @default(now())

  @@index([tagId, createdAt])
  @@index([zoneId, createdAt])
}

model RFIDAlertRule {
  id             String      @id @default(cuid())
  type           String      // ZONE_BREACH | RESTRICTED_ZONE | MISSING | LOW_BATTERY
  name           String
  enabled        Boolean     @default(true)
  config         Json        // { thresholdMinutes, batteryThreshold, zoneId, ... }
  organizationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  alerts         RFIDAlert[]
}

model RFIDAlert {
  id             String         @id @default(cuid())
  ruleId         String
  rule           RFIDAlertRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tagId          String?
  tag            RFIDTag?       @relation(fields: [tagId], references: [id], onDelete: SetNull)
  assetId        String?
  assetName      String?
  zoneName       String?
  message        String
  severity       String         // INFO | WARNING | CRITICAL
  resolvedAt     DateTime?
  organizationId String?
  createdAt      DateTime       @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, resolvedAt])
}
