# ──────────────────────────────────────────────────────────────────────────────
# AssetXAI Mobile — Environment Variables
# Copy this file to .env and fill in the values.
# For production EAS builds, set these as EAS secrets instead:
#   eas secret:create --name EXPO_PUBLIC_SUPABASE_URL --value "..."
# ──────────────────────────────────────────────────────────────────────────────

# Web API base URL (production)
EXPO_PUBLIC_API_URL=https://assetxai.live

# Supabase project credentials — find in Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
