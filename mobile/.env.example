# ──────────────────────────────────────────────────────────────────────────────
# AssetXAI Mobile — Environment Variables
# Copy this file to .env and fill in the values.
# For production EAS builds, set these in Expo (Project → Environment variables)
# or `eas env:create` for the **same project** as app.json extra.eas.projectId.
# If you create a new Expo account/project, you must add them again — missing
# values cause startup failures when anything touches Supabase.
# ──────────────────────────────────────────────────────────────────────────────

# Web API base URL (production)
EXPO_PUBLIC_API_URL=https://assetxai.live

# Supabase project credentials — find in Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
