{
  "expo": {
    "name": "AssetXAI",
    "slug": "assetxai",
    "version": "2.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "assetxai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.assetxai.app",
      "buildNumber": "2",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "AssetXAI uses the camera to scan barcodes and QR codes for asset tracking.",
        "NSPhotoLibraryUsageDescription": "AssetXAI can attach photos to audit comments and assets.",
        "NSBluetoothAlwaysUsageDescription": "AssetXAI uses Bluetooth to connect to RFID readers and handheld scanners.",
        "NSBluetoothPeripheralUsageDescription": "AssetXAI uses Bluetooth to connect to RFID readers.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInWebContent": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "package": "com.assetxai.app",
      "versionCode": 6,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "privacyPolicyUrl": "https://assetxai.live/privacy",
      "eas": {
        "projectId": "f7c4e00d-e7e1-4be3-a0d6-1eb3190a49ac"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AssetXAI to access your camera to scan barcodes and QR codes."
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "king0079z"
  }
}
