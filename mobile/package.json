{
  "name": "assetxai-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "push-to-stores": "node scripts/push-to-stores.js",
    "push-to-stores:build": "node scripts/push-to-stores.js --build-only",
    "push-to-stores:submit": "node scripts/push-to-stores.js --submit-only"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.5",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.0",
    "typescript": "~5.3.0"
  },
  "private": true
}
