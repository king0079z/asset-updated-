<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
  <Id>a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d</Id>
  <Version>1.0.0</Version>
  <ProviderName>Asset AI</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Asset AI – Submit Ticket"/>
  <Description DefaultValue="Submit a support or asset ticket directly from Outlook. One click to open the task pane and send your request."/>
  <IconUrl DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/icon-80.png"/>
  <SupportUrl DefaultValue="https://YOUR_DEPLOYMENT_URL"/>
  <AppDomains>
    <AppDomain>https://YOUR_DEPLOYMENT_URL</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/taskpane"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="ReadOrEdit"/>
  </Rule>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets>
        <bt:Set Name="Mailbox" MinVersion="1.5"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="TaskPane.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="AssetAIGroupRead">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="SubmitTicketButton">
                  <Label resid="TaskPaneButtonLabel"/>
                  <Supertip>
                    <Title resid="TaskPaneButtonLabel"/>
                    <Description resid="TaskPaneButtonDescription"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskPane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/icon-16.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskPane.Url" DefaultValue="https://YOUR_DEPLOYMENT_URL/outlook/taskpane"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Asset AI"/>
        <bt:String id="TaskPaneButtonLabel" DefaultValue="Submit Ticket"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskPaneButtonDescription" DefaultValue="Open the task pane to submit a support or asset ticket directly from Outlook."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
